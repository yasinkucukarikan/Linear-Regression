#kütüphaneleri yükleyelim
import numpy as np
import matplotlib.pyplot as plt
import pandas as pd
#veri setini aktaralım
veriseti=pd.read_csv('Bascevuz.csv')
veriseti.head()

#bağımlı bağımsız değişkenleri aktaralım
X=veriseti['Bas_cevresi(cm^3)'].values
y=veriseti['Beyin_agirligi(gr)'].values
uzunluk=len(X)
X=X.reshape(uzunluk,1)

#eğitim ve test veri setini oluşturalım. (%70 eğitim, %30 test)
from sklearn.model_selection import train_test_split
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=0)

#eğitim setinin lineer regresyona göre uydurma
from sklearn.linear_model import LinearRegression
model_Regresyon=LinearRegression()
model_Regresyon.fit(X_train,y_train)

#test seti sonuçlarının tathim edilmesi
y_pred=model_Regresyon.predict(X_test)

#eğitim seti sonuçlarının grafiğinin çizilmesi
plt.scatter(X_train,y_train,color='red')
plt.plot(X_train,model_Regresyon.predict(X_train),color='blue')
plt.title('Basın cevre uzunluğu ve beyin ağırlığı (eğitim veri seti)')
plt.xlabel('Bas_cevresi(cm^3)')
plt.ylabel('Beyin_agirligi(gr)')
plt.show()

#test seti sonuçlarının grafiğinin çizilmesi
plt.scatter(X_test,y_test,color='red')
plt.plot(X_train,model_Regresyon.predict(X_train),color='blue')
plt.title('Basın cevre uzunluğu ve beyin ağırlığı (test veri seti)')
plt.xlabel('Bas_cevresi(cm^3)')
plt.ylabel('Beyin_agirligi(gr)')
plt.show()

#regresyon denklemi katsayıları (y=ax+b'deki a ve b'yi bulalım)
print('Eğim(Q1):', model_Regresyon.coef_)
print('Kesen(Q0):', model_Regresyon.intercept_)


#regresyon denklemi
print("y=%0.2f"%model_Regresyon.coef_+"x+%2f"%model_Regresyon.intercept_)

#test veri seti performansı
from sklearn.metrics import explained_variance_score, mean_absolute_error, mean_squared_error
from sklearn.metrics import median_absolute_error, r2_score, mean_absolute_percentage_error
print("R-kare: ", r2_score(y_test, y_pred))
print("Ortalama Mutlak Hata: ", mean_absolute_error(y_test, y_pred))
print("Ortalama Kare Hata: ", mean_squared_error(y_test, y_pred))
print("Ortalama Kare Hatanın karekökü: ", np.sqrt(mean_squared_error(y_test, y_pred)))
print("Medyan Mutlak Hata: ", median_absolute_error(y_test, y_pred))
print("ortalama mutlak yüzde hatası: ", mean_absolute_percentage_error(y_test, y_pred))
